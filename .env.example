# ─────────────────────────────────────────────────────────────────────────────
# MT5 Connection
# ─────────────────────────────────────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_demo_password
MT5_SERVER=Broker-Demo
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ─────────────────────────────────────────────────────────────────────────────
# Trading Instrument
# ─────────────────────────────────────────────────────────────────────────────
SYMBOL=EURUSD
SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,USDCAD,NZDUSD,XAUUSD
SYMBOL_DISCOVERY_MODE=VISIBLE
PAIR_FILTER_MODE=MAJORS
PAIR_INCLUDE=
PAIR_EXCLUDE=
PAIR_MAX_VOLUME_MIN=1.0
SCAN_MAX_SYMBOLS=50

# ─────────────────────────────────────────────────────────────────────────────
# Data Historis
# Untuk backtest M15 (46 bulan): ~132.000 bar diperlukan
# M15 = 4 bar/jam x 22 jam/hari x 5 hari/minggu x ~200 minggu/46 bulan
# ─────────────────────────────────────────────────────────────────────────────
BARS_H1=10000
BARS_H4=5000
BARS_M15=135000       # 46 bulan data M15 (buffer 20% sudah termasuk)
BARS_M1=100000
MIN_BARS_REQUIRED=800
MAX_SIGNAL_BAR_AGE_HOURS=168
MAX_ACTIVE_PAIRS=3

# ─────────────────────────────────────────────────────────────────────────────
# Timeframe
# Backtest M15+H1 (untuk 15 menit trading)
# Backtest default H1+H4
# ─────────────────────────────────────────────────────────────────────────────
BACKTEST_FAST_TF=M15
BACKTEST_SLOW_TF=H1
LIVE_FAST_TF=M15
LIVE_SLOW_TF=H1

# ─────────────────────────────────────────────────────────────────────────────
# Model & Training
# ─────────────────────────────────────────────────────────────────────────────
LOOKBACK=96
RETRAIN_EVERY_BARS=24
EPOCHS=30
BATCH_SIZE=64
LEARNING_RATE=0.0008
# Threshold lebih ketat = lebih sedikit sinyal = sinyal lebih berkualitas
PRED_BUY_THRESHOLD=0.60
PRED_SELL_THRESHOLD=0.40

# ─────────────────────────────────────────────────────────────────────────────
# Risk Management – DIOPTIMASI untuk modal kecil (100 USD)
# ─────────────────────────────────────────────────────────────────────────────
RISK_PROFILE=SEDANG         # KECIL | SEDANG | BESAR
INITIAL_BALANCE=100.0       # Modal awal 100 USD

# Risk 1% per trade dari balance (bukan fixed lot)
RISK_PER_TRADE=0.01
USE_RISK_POSITION_SIZING=true
FIXED_LOT=0.01              # Fallback jika USE_RISK_POSITION_SIZING=false

# Stop Loss & Take Profit (dalam pip)
# Rasio R:R = 1:2 (SL=20, TP=40) → minimal win rate 34% sudah profit
STOP_LOSS_PIPS=20.0
TAKE_PROFIT_PIPS=40.0

# Trailing Stop – geser SL mengikuti harga yang menguntungkan
USE_TRAILING_STOP=true
TRAILING_STOP_PIPS=12.0     # SL bergerak 12 pip di belakang harga

# Circuit Breaker – hentikan entry baru jika drawdown mencapai batas ini
MAX_DRAWDOWN_CIRCUIT_BREAKER=0.15   # 15% dari balance

# Consecutive Loss Guard – pause entry setelah N kerugian berturut-turut
MAX_CONSECUTIVE_LOSSES=5

# Spread filter (filter simbol dengan spread terlalu lebar)
MAX_SPREAD_POINTS=30
DEVIATION=20
MAGIC_NUMBER=20260312

# ─────────────────────────────────────────────────────────────────────────────
# Live Loop
# ─────────────────────────────────────────────────────────────────────────────
POLL_SECONDS=30
LIVE_SLEEP_SECONDS=10
